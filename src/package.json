        "string-similarity": "^4.0.4",
        "strip-ansi": "^7.1.0",
        "strip-bom": "^5.0.0",
        "tiktoken": "^1.0.21",
        "tmp": "^0.2.3",
        "tree-sitter-wasms": "^0.1.12",
        "turndown": "^7.2.0",
        "undici": "^6.21.3",
        "uuid": "^11.1.0",
        "vscode-material-icons": "^0.1.1",
        "web-tree-sitter": "^0.25.6",
        "workerpool": "^9.2.0",
        "yaml": "^2.8.0",
        "zhipu-ai-provider": "^0.2.2",
        "zod": "3.25.76"
    },
    "devDependencies": {
        "@ai-sdk/openai-compatible": "^2.0.28",
        "@openrouter/ai-sdk-provider": "^2.1.1",
        "@meow-code/build": "workspace:^",
        "@meow-code/config-eslint": "workspace:^",
        "@meow-code/config-typescript": "workspace:^",
        "@types/clone-deep": "^4.0.4",
        "@types/debug": "^4.1.12",
        "@types/diff": "^5.2.1",
        "@types/diff-match-patch": "^1.0.36",
        "@types/glob": "^8.1.0",
        "@types/lodash.debounce": "^4.0.9",
        "@types/mocha": "^10.0.10",
        "@types/node": "20.x",
        "@types/node-cache": "^4.1.3",
        "@types/node-ipc": "^9.2.3",
        "@types/proper-lockfile": "^4.1.4",
        "@types/ps-tree": "^1.1.6",
        "@types/semver-compare": "^1.0.3",
        "@types/shell-quote": "^1.7.5",
        "@types/stream-json": "^1.7.8",
        "@types/string-similarity": "^4.0.2",
        "@types/tmp": "^0.2.6",
        "@types/turndown": "^5.0.5",
        "@types/vscode": "^1.84.0",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "3.3.2",
        "ai": "^6.0.75",
        "esbuild-wasm": "^0.25.0",
        "execa": "^9.5.2",
        "glob": "^11.1.0",
        "mkdirp": "^3.0.1",
        "nock": "^14.0.4",
        "npm-run-all2": "^8.0.1",
        "ovsx": "0.10.4",
        "rimraf": "^6.0.1",
        "tsup": "^8.4.0",
        "tsx": "^4.19.3",
        "vitest": "^3.2.3",
        "zod-to-ts": "^1.2.0"
    }
}
